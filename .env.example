# Copy this file to .env and fill in your real key. Never commit .env to GitHub.

# Groq API key — used ONLY server-side by /api/kai.js (Kai's chatbot backend).
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gmail credentials — used ONLY server-side by /api/notify.js to send the
# contact-form auto-reply email. GMAIL_APP_PASSWORD is a 16-character App
# Password (not your real Gmail password) generated at
# https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
